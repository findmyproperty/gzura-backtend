DB_HOST=your-mysql-host
DB_PORT=3306
DB_USERNAME=your-username
DB_PASSWORD=your-password
DB_DATABASE=gzura_development
DB_SSL=false
DB_SYNC=false

JWT_SECRET=generate-a-strong-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
PORT=3001

# Google Calendar + Meet (required for auto-creating online event links)
# Option A: OAuth refresh token
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REFRESH_TOKEN=

# Option B: Service account with domain-wide delegation
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_IMPERSONATE_EMAIL=

GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata

# Google Maps / Places (location search for offline events)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Event thumbnail uploads
# local = save on this server (dev). sftp = push to Hostinger VPS public folder.
UPLOAD_STORAGE=sftp
UPLOAD_LOCAL_DIR=./uploads/events
UPLOAD_PUBLIC_URL=https://gzura.com/uploads/events
UPLOAD_CONTENT_PUBLIC_URL=https://api.theybdc.com/uploads/event-content
UPLOAD_CONTENT_LOCAL_DIR=./uploads/event-content
UPLOAD_DOMAIN=gzura.com

# Hostinger VPS (SFTP)
SFTP_HOST=187.127.133.141
SFTP_PORT=22
SFTP_USER=your-ssh-username
SFTP_PASSWORD=your-ssh-password
# SFTP_PRIVATE_KEY_PATH=/path/to/id_rsa
# SFTP_PRIVATE_KEY_PASSPHRASE=
SFTP_REMOTE_PATH=/home/your-user/domains/gzura.com/public_html/uploads/events
SFTP_CONTENT_REMOTE_PATH=/public_html/uploads/event-content