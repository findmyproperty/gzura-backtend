{
  "name": "gzura-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "prod": "pnpm build && pnpm start:prod",
    "pm2:start": "pnpm build && pm2 start dist/main.js --name gzura-backend",
    "pm2:restart": "pm2 restart gzura-backend",
    "pm2:stop": "pm2 stop gzura-backend",
    "pm2:delete": "pm2 delete gzura-backend",
    "pm2:logs": "pm2 logs gzura-backend",
    "seed": "ts-node src/database/seed.ts",
    "setup:vps-upload": "node scripts/setup-vps-upload.js",
    "configure:vps-nginx": "node scripts/configure-vps-uploads-nginx.js",
    "google:auth": "node scripts/get-google-refresh-token.js",
    "google:verify": "node scripts/verify-google-calendar.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "googleapis": "^173.0.0",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ssh2-sftp-client": "^12.0.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.10",
    "@types/passport-jwt": "^4.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
